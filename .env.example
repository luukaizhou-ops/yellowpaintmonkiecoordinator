# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
#
# Find both values in your Supabase dashboard:
#   Project Settings (gear icon) -> Data API  -> Project URL
#   Project Settings (gear icon) -> API Keys   -> anon / public key
#
# The "anon" key is safe to expose in a frontend app AS LONG AS you have
# Row Level Security policies set up (see README / supabase-setup.sql).
# Do NOT put the "service_role" key here — that one is a secret.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
